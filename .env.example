# =========================================================================
# file-processor environment. Copy to .env and fill in. .env is git-ignored.
# Only needs the shared DB + Redis (ARQ broker — MUST match core-api's Redis).
# =========================================================================

DEV_MODE=False
ENABLE_PERFORMANCE_LOGGER=True

# --- Shared PostgreSQL cluster ---
DB_USER=
DB_PASSWORD=
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=ai12_main, ai12_service, ai12_users, aixii_cirium, aixii_airlabs, flightradar, powerplatform, aviationedge

# --- Shared Redis (status:events channel — same instance as core-api) ---
REDIS_USER=
REDIS_USER_PASSWORD=
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# --- HTTP intake server ---
# HOST=0.0.0.0
# PORT=8000
# Token core-api must present (X-Service-Token) when forwarding a file. Must equal
# core-api's FILE_PROCESSOR_TOKEN.
SERVICE_TOKEN=
# Concurrent processing workers (queue consumers). Higher = more files at once.
# FP_WORKERS=2
